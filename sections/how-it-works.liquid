<section class="how-section" id="how-it-works">
  <div style="max-width: 1280px; margin: 0 auto;">
    <div class="section-eyebrow">{{ section.settings.eyebrow | default: 'The Process' }}</div>
    <h2 class="section-title">{{ section.settings.title | default: 'How It Works' }}</h2>
    <p class="section-sub">{{ section.settings.subtitle | default: 'Open your account once. Design, approve, and reorder apartment signs online anytime.' }}</p>
    <div class="how-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="how-step" {{ block.shopify_attributes }}>
            <div class="how-num">{{ forloop.index }}</div>
            <h3>{{ block.settings.heading }}</h3>
            <p>{{ block.settings.body }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Open your account once. Design, approve, and reorder apartment signs online anytime."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Apply"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Tell us about your property."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "settings": {},
    "blocks": [
      {
        "type": "step",
        "settings": {
          "heading": "Apply",
          "body": "Tell us about your property, management company, or portfolio. Apartment-community accounts are typically reviewed the same business day."
        }
      },
      {
        "type": "step",
        "settings": {
          "heading": "Customize",
          "body": "Choose your sign, add your logo and text, and see an instant proof as you customize."
        }
      },
      {
        "type": "step",
        "settings": {
          "heading": "Approve",
          "body": "Review your proof and approve the order when everything looks right. Production starts after approval."
        }
      },
      {
        "type": "step",
        "settings": {
          "heading": "Produced & Shipped Free",
          "body": "Standard signs can arrive in as little as 3 business days, with free shipping to the lower 48."
        }
      }
    ]
  }
}
{% endschema %}
