{%- comment -%}
  Brand pillars / "Why SignageWorks" — 4 hover cards explaining the value props.
  Each pillar is a block so the merchant can add/remove/reorder.
{%- endcomment -%}

<section class="stats-strip" aria-label="Why SignageWorks">
  <div class="stats-row">
    {%- for block in section.blocks -%}
      {%- if block.type == 'pillar' -%}
        {%- assign color = block.settings.color | default: 'cyan' -%}
        <div class="pillar-card {{ color }}" {{ block.shopify_attributes }}>
          <div class="pillar-icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'building' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1.5"/><line x1="7" y1="7" x2="9" y2="7"/><line x1="11" y1="7" x2="13" y2="7"/><line x1="15" y1="7" x2="17" y2="7"/><line x1="7" y1="11" x2="9" y2="11"/><line x1="11" y1="11" x2="13" y2="11"/><line x1="15" y1="11" x2="17" y2="11"/><line x1="7" y1="15" x2="9" y2="15"/><line x1="15" y1="15" x2="17" y2="15"/><path d="M10 21v-3h4v3"/></svg>
              {%- when 'bolt' -%}
                <svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M13 2L4 14h6l-2 8 10-13h-6l1-7z"/></svg>
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8h11v9H2z"/><path d="M13 12h4l3 3v2h-7z"/><circle cx="6.5" cy="18.5" r="1.7"/><circle cx="16.5" cy="18.5" r="1.7"/></svg>
              {%- when 'document' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H6a2 2 0 00-2 2v14a2 2 0 002 2h12a2 2 0 002-2V9z"/><path d="M14 3v6h6"/><path d="M9 14l2 2 4-4"/></svg>
            {%- endcase -%}
          </div>
          <div class="pillar-heading">{{ block.settings.heading }}</div>
          <div class="pillar-body">{{ block.settings.body }}</div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.disclaimer != blank -%}
    <p class="pillar-disclaimer">{{ section.settings.disclaimer }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Brand Pillars",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Disclaimer below cards",
      "default": "<p><strong>Standard sign orders can arrive in as little as 3 business days after approval.</strong> Custom, oversized, bulk, monument, or revised orders may require additional time.</p>"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar card",
      "settings": [
        {
          "type": "select",
          "id": "color",
          "label": "Accent color",
          "options": [
            { "value": "cyan", "label": "Cyan" },
            { "value": "magenta", "label": "Magenta" },
            { "value": "yellow", "label": "Yellow" }
          ],
          "default": "cyan"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "building", "label": "Building" },
            { "value": "bolt", "label": "Lightning bolt" },
            { "value": "truck", "label": "Truck" },
            { "value": "document", "label": "Document check" }
          ],
          "default": "building"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Built for Apartments"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>Signage made for apartment communities, managers &amp; portfolios.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "default": {
    "settings": {},
    "blocks": [
      { "type": "pillar", "settings": { "color": "cyan", "icon": "building", "heading": "Built for Apartments", "body": "<p>Signage made for apartment communities, managers &amp; portfolios.</p>" } },
      { "type": "pillar", "settings": { "color": "magenta", "icon": "bolt", "heading": "Fast Turnaround", "body": "<p>Standard signs can arrive in as little as <strong style=\"color:#fff;\">3 business days</strong>.</p>" } },
      { "type": "pillar", "settings": { "color": "yellow", "icon": "truck", "heading": "Free Shipping", "body": "<p>No added shipping fees at checkout.</p>" } },
      { "type": "pillar", "settings": { "color": "cyan", "icon": "document", "heading": "Instant Online Proofs", "body": "<p>Create, proof &amp; approve your signs online <strong style=\"color:#fff;\">24/7</strong>.</p>" } }
    ]
  },
  "presets": [
    { "name": "Brand Pillars" }
  ]
}
{% endschema %}
