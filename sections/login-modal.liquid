<div class="modal-overlay hidden" id="login-modal">
  <div class="modal-card">
    <span class="modal-close-x" onclick="closeModal('login-modal')">&times;</span>
    <h2>{{ section.settings.heading | default: 'Log In' }}</h2>
    <p class="modal-sub">{{ section.settings.sub | default: 'Welcome back. Sign in to design and order your apartment signs.' }}</p>

    <label class="field-label">{{ section.settings.label_email | default: 'Email' }}</label>
    <input type="email" name="email" placeholder="you@property.com">

    <label class="field-label">{{ section.settings.label_password | default: 'Password' }}</label>
    <input type="password" name="password" placeholder="••••••••">

    <div style="margin-top: 8px; font-size: 12px;">
      <a style="color: var(--cyan); cursor: pointer;">{{ section.settings.forgot_label | default: 'Forgot password?' }}</a>
    </div>

    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeModal('login-modal')">{{ section.settings.cancel_label | default: 'Cancel' }}</button>
      <button class="modal-submit" onclick="doLogin()">{{ section.settings.submit_label | default: 'Log In →' }}</button>
    </div>

    {%- if section.settings.footnote != blank -%}
      <p style="font-size: 11px; color: var(--muted); margin-top: 14px; text-align: center;">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Login Modal",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Log In" },
    { "type": "textarea", "id": "sub", "label": "Subheading", "default": "Welcome back. Sign in to design and order your apartment signs." },
    { "type": "text", "id": "label_email", "label": "Email field label", "default": "Email" },
    { "type": "text", "id": "label_password", "label": "Password field label", "default": "Password" },
    { "type": "text", "id": "forgot_label", "label": "Forgot password link", "default": "Forgot password?" },
    { "type": "text", "id": "cancel_label", "label": "Cancel button", "default": "Cancel" },
    { "type": "text", "id": "submit_label", "label": "Log In button", "default": "Log In →" },
    { "type": "textarea", "id": "footnote", "label": "Footnote (e.g. prototype notice)", "default": "" }
  ]
}
{% endschema %}
