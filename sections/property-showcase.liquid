<section class="section" id="showcase">
  <div class="section-eyebrow">{{ section.settings.eyebrow | default: 'Our Work' }}</div>
  <h2 class="section-title">{{ section.settings.title | default: 'Property Showcase' }}</h2>
  <p class="section-sub">{{ section.settings.subtitle | default: 'See SignageWorks signs installed at real apartment communities. Coming soon — and we credit every property that lets us feature their installation.' }}</p>

  <div class="showcase-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'showcase' -%}
        <div class="showcase-card" {{ block.shopify_attributes }}>
          <div class="showcase-photo">
            {%- if block.settings.photo != blank -%}
              <img src="{{ block.settings.photo | image_url: width: 600 }}" alt="{{ block.settings.name | escape }}" style="width:100%;height:100%;object-fit:cover;">
            {%- else -%}
              <div class="showcase-placeholder">
                <div class="showcase-icon">{{ block.settings.icon | default: '🏢' }}</div>
                <div class="showcase-label">{{ block.settings.label }}</div>
              </div>
            {%- endif -%}
          </div>
          <div class="showcase-meta">
            <div class="showcase-name">{{ block.settings.name }}</div>
            <div class="showcase-loc">{{ block.settings.loc }}</div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_text != blank -%}
    <div class="showcase-cta">
      <div class="showcase-cta-icon">{{ section.settings.cta_icon | default: '📸' }}</div>
      <div class="showcase-cta-text">{{ section.settings.cta_text }}</div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Property Showcase",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Work"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Property Showcase"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See SignageWorks signs installed at real apartment communities. Coming soon — and we credit every property that lets us feature their installation."
    },
    {
      "type": "header",
      "content": "Call-to-action banner"
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "CTA icon (emoji)",
      "default": "📸"
    },
    {
      "type": "richtext",
      "id": "cta_text",
      "label": "CTA text",
      "default": "<p><strong>Featured a SignageWorks install at your property?</strong> Share a photo and get <span style=\"color: var(--yellow); font-weight: 800;\">10% off your next order.</span></p>"
    }
  ],
  "blocks": [
    {
      "type": "showcase",
      "name": "Showcase card",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo (optional — placeholder if blank)"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Placeholder icon (emoji)",
          "default": "🏢"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Placeholder label",
          "default": "Monument Replacement"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Coastal Community Monument"
        },
        {
          "type": "text",
          "id": "loc",
          "label": "Detail (finish · size · count)",
          "default": "Summit View · 48\"×96\""
        }
      ]
    }
  ],
  "max_blocks": 12,
  "default": {
    "settings": {},
    "blocks": [
      {
        "type": "showcase",
        "settings": {
          "icon": "🏢",
          "label": "Monument Replacement",
          "name": "Coastal Community Monument",
          "loc": "Summit View · 48\"×96\""
        }
      },
      {
        "type": "showcase",
        "settings": {
          "icon": "🏊",
          "label": "Pool Area Package",
          "name": "Full Pool Compliance Set",
          "loc": "Metro Beach · 4 signs"
        }
      },
      {
        "type": "showcase",
        "settings": {
          "icon": "🚪",
          "label": "Unit Number Refresh",
          "name": "230-Unit Property Refresh",
          "loc": "Metro Beach · 230 unit numbers"
        }
      },
      {
        "type": "showcase",
        "settings": {
          "icon": "🏘️",
          "label": "Full Community Package",
          "name": "ShadowMoss Pointe",
          "loc": "Summit View · 180 signs"
        }
      }
    ]
  }
}
{% endschema %}
